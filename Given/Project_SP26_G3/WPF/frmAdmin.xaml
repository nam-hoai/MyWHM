<Window x:Class="WPF.frmAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="AdminDashBoard" Height="650" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TabControl  Background="LightBlue" Margin="10" Grid.Row="0">
            <TabItem Header="Account Management"
                     DataContext="{Binding AccountVM}">
                <StackPanel>
                    <DataGrid  ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                               AutoGenerateColumns="False" Margin="10" Width="700">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <!-- Active -->
                                    <DataTrigger Binding="{Binding Status}" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </DataTrigger>
                                    <!-- Deactive -->
                                    <DataTrigger Binding="{Binding Status}" Value="False">
                                        <Setter Property="Background" Value="Gray"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PersonId}" Width="*"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding PersonName}" Width="*"/>
                            <DataGridTextColumn Header="Password" Binding="{Binding Password}"/>
                            <DataGridTextColumn Header="Date Of Birth" Binding="{Binding Birthdate}" Width="*"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Header="Detail Info" Width="700" Margin="10" Background="LightGray">
                        <WrapPanel Margin="5">
                            <StackPanel Margin="5" Width="500">
                                <WrapPanel>
                                    <Label Content="Person ID" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormAccount.PersonId, Mode=TwoWay}" 
                                             Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Person Name" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormAccount.PersonName, Mode=TwoWay}" 
                                             Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Password" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormAccount.Password, Mode=TwoWay}" 
                                             Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Date Of Birth" Width="100" Margin="5" FontWeight="Bold"/>
                                    <DatePicker SelectedDate="{Binding FormAccount.Birthdate, Mode=TwoWay}" 
                                                Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Address" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormAccount.Address, Mode=TwoWay}" 
                                             Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Phone" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormAccount.Phone, Mode=TwoWay}" 
                                             Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Status" Width="100" Margin="5" FontWeight="Bold"/>
                                    <WrapPanel Width="350" Margin="5" VerticalAlignment="Center">
                                        <RadioButton    Content="Active" GroupName="Status"
                                                        IsChecked="{Binding FormAccount.Status,Mode=TwoWay,
                                                                    UpdateSourceTrigger=PropertyChanged}" />

                                        <RadioButton    Content="Deactive" GroupName="Status"
                                                        IsChecked="{Binding FormAccount.Status,Mode=TwoWay,
                                                                    UpdateSourceTrigger=PropertyChanged}" />
                                    </WrapPanel>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel>
                                <Button Width="100" Margin="5" Content="ADD" Command="{Binding AddCommand}"/>
                                <Button Width="100" Margin="5" Content="EDIT" Command="{Binding EditCommand}"/>
                                <Button Width="100" Margin="5" Content="DELETE" Command="{Binding DeleteCommand}"/>
                                <Button Width="100" Margin="5" Content="SEARCH" Command="{Binding SearchCommand}"/>
                                <Button Width="100" Margin="5" Content="RESET" Command="{Binding ResetCommand}"/>
                                <Button Width="100" Margin="5" Content="BACKLOG DATA" Command="{Binding BacklogCommand}"/>
                                <Button Width="100" Margin="5" Content="GENERATE DATA" Command="{Binding ReportCommand}"/>
                            </StackPanel>
                        </WrapPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Wasehose Configuration">
                <StackPanel>
                    <DataGrid x:Name="lstHouse" Margin="10" Width="700" AutoGenerateColumns="False" SelectionChanged="lstHouse_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding WarehouseId}" Width="*"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding WarehouseName}" Width="5*"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="2*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Header="Detail Info" Width="700" Margin="10" Background="LightGray">
                        <WrapPanel Margin="5">
                            <StackPanel Margin="5" Width="500">
                                <WrapPanel>
                                    <Label Content="Wasehouse ID" Width="120" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtId1" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Wasehouse Name" Width="120" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtName1" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Size" Width="120" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtSize" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Status" Width="120" Margin="5" FontWeight="Bold"/>
                                    <WrapPanel Width="350" Margin="5" VerticalAlignment="Center">
                                        <RadioButton x:Name="rbEnable1" Content="Enable" GroupName="Status" IsChecked="true"/>
                                        <RadioButton x:Name="rbDisable1" Content="Disable" GroupName="Status"/>
                                    </WrapPanel>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel>
                                <Button Width="100" Margin="5" Content="ADD" Command="{Binding AddCommand}"/>
                                <Button Width="100" Margin="5" Content="EDIT" Command="{Binding EditCommand}"/>
                                <Button Width="100" Margin="5" Content="DELETE" Command="{Binding DeleteCommand}"/>
                                <Button Width="100" Margin="5" Content="SEARCH" Command="{Binding SearchCommand}"/>
                                <Button Width="100" Margin="5" Content="RESET" Command="{Binding ResetCommand}"/>
                                <Button Width="100" Margin="5" Content="BACKLOG DATA" Command="{Binding BacklogCommand}"/>
                                <Button Width="100" Margin="5" Content="GENERATE DATA" Command="{Binding ReportCommand}"/>
                            </StackPanel>
                        </WrapPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Product Catalog">
                <StackPanel>
                    <DataGrid x:Name="lstProduct" Margin="10" Width="700" AutoGenerateColumns="False" SelectionChanged="lstProduct_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding ProductName}"/>
                            <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}"/>
                            <DataGridTextColumn Header="Sender" Binding="{Binding Sender}"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}"/>
                            <DataGridTextColumn Header="Category Name" Binding="{Binding CatName}"/>
                            <DataGridTextColumn Header="Dat Stock In" Binding="{Binding DateIn}"/>
                            <DataGridTextColumn Header="Date Stock Out" Binding="{Binding DateOut}"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Header="Detail Info" Width="700" Margin="10" Background="LightGray">
                        <WrapPanel Margin="5">
                            <StackPanel Margin="5" Width="500">
                                <WrapPanel>
                                    <Label Content="Product ID" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtId" Width="350" Margin="5" IsReadOnly="true"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Product Name" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtName" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Product Code" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtCode" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Quantity" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtQuantity" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Seneder" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtSender" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Location" Width="100" Margin="5" FontWeight="Bold"/>
                                    <TextBox x:Name="txtLocation" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Category Name" Width="100" Margin="5" FontWeight="Bold"/>
                                    <ComboBox x:Name="cboCat" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Date Stock In" Width="100" Margin="5" FontWeight="Bold"/>
                                    <DatePicker x:Name="txtDateIn" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Date Stock Out" Width="100" Margin="5" FontWeight="Bold"/>
                                    <DatePicker x:Name="txtDateOut" Width="350" Margin="5"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Label Content="Status" Width="100" Margin="5" FontWeight="Bold"/>
                                    <WrapPanel Width="350" Margin="5" VerticalAlignment="Center">
                                        <RadioButton x:Name="rbEnable" Content="Enable" GroupName="Status" IsChecked="true"/>
                                        <RadioButton x:Name="rbDisable" Content="Disable" GroupName="Status"/>
                                    </WrapPanel>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel>
                                <Button Width="100" Margin="5" Content="ADD" Command="{Binding AddCommand}"/>
                                <Button Width="100" Margin="5" Content="EDIT" Command="{Binding EditCommand}"/>
                                <Button Width="100" Margin="5" Content="DELETE" Command="{Binding DeleteCommand}"/>
                                <Button Width="100" Margin="5" Content="SEARCH" Command="{Binding SearchCommand}"/>
                                <Button Width="100" Margin="5" Content="RESET" Command="{Binding ResetCommand}"/>
                                <Button Width="100" Margin="5" Content="BACKLOG DATA" Command="{Binding BacklogCommand}"/>
                                <Button Width="100" Margin="5" Content="GENERATE DATA" Command="{Binding ReportCommand}"/>
                            </StackPanel>
                        </WrapPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Reporting Generation">
                <StackPanel>
                    <GroupBox Header="File Control" Width="700" Margin="10" Background="LightGray">
                        <StackPanel>
                            <WrapPanel Margin="5">
                                <Label Content="File Name: " Margin="5" Width="100" FontWeight="Medium" FontSize="14"/>
                                <TextBox x:Name="txtName3" Margin="5" Width="350"/>
                                <Button x:Name="btnSearch3" Content="SEARCH" Margin="5" Width="150" Click="btnSearch3_Click"/>
                            </WrapPanel>
                            <DataGrid x:Name="lstFile" Width="700" Margin="10" SelectionChanged="lstFile_SelectionChanged" AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="*" Binding="{Binding FileName}"/>
                                    <DataGridTextColumn Header="Path" Width="*" Binding="{Binding FilePath}"/>
                                    <DataGridTextColumn Header="CreatedAt" Width="*" Binding="{Binding CreatedAt}"/>
                                    <DataGridTextColumn Header="Size" Width="*" Binding="{Binding FileSize}"/>
                                    <DataGridTemplateColumn Header="Actions" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WrapPanel>
                                                    <Button x:Name="btnExprot" Content="Export" Click="btnExprot_Click"/>
                                                    <Button x:Name="btnRemove" Content="Delete" Click="btnRemove_Click"/>
                                                </WrapPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button x:Name="btnBacklog3" Content="BACKLOG DATA" Width="100" HorizontalAlignment="Right" Margin="5" Click="btnBacklog3_Click"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Content" Width="700" Margin="10" Background="LightGray">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox x:Name="txtShow" Margin="5" Width="600" Height="200" TextWrapping="Wrap"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="0" IsReadOnly="true"/>
                            <Button x:Name="btnClear" Grid.Row="1" Content="CLEAR UP" Width="100" HorizontalAlignment="Right" Click="btnClear_Click"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>
        <WrapPanel Grid.Row="1">
            <Button x:Name="btnOut" Content="Exit" Width="100" Margin="10" Click="btnOut_Click"/>
        </WrapPanel>
    </Grid>
</Window>
