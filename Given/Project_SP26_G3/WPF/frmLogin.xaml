<Window x:Class="WPF.frmLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    
    <Grid Background="LightSkyBlue">
        <StackPanel Background="LightGreen" Margin="50">
            <Label Content="Login In" 
                   HorizontalAlignment="Center"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="red"/>
            <WrapPanel>
                <StackPanel Width="450">
                    <Label  Content="Username"
                            FontSize="16"
                            FontWeight="Bold"/>
                    <TextBox    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                Margin="10"
                                HorizontalAlignment="Left"
                                Width="200"/>
                    <Label  Content="Password"
                            FontSize="16"
                            FontWeight="Bold"/>
                    <WrapPanel>
                        <Grid>
                            <!-- PasswordBox -->
                            <PasswordBox x:Name="passBox"
                                         Width="200"
                                         Margin="10"
                                         HorizontalAlignment="Left"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            <!-- TextBox display password -->
                            <TextBox    x:Name="txtVisiblePassword"
                                        Width="200"
                                        Margin="10"
                                        Visibility="Collapsed"/>
                        </Grid>
                        <!-- checkbox show password -->
                        <CheckBox   Content="Show Password"
                                    Margin="10"
                                    Checked="ShowPassword_Checked"
                                    Unchecked="ShowPassword_Unchecked"/>
                    </WrapPanel>
                    <WrapPanel>
                        <!-- Button login -->
                        <Button Content="Login" 
                                Width="100" 
                                Margin="10" 
                                Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=passBox}"/>
                        <!-- Button forget password -->
                        <Button Content="Forget Password" 
                                Width="100" 
                                Margin="10" 
                                Command="{Binding ForgetCommand}"/>
                        <!-- Button exit -->
                        <Button Content="Exit" 
                                Width="100" 
                                Margin="10" 
                                Command="{Binding CloseCommand}"/>
                    </WrapPanel>
                </StackPanel>
                <StackPanel>
                    <Image  Source="1746650.png"
                            Width="200" Height="200" 
                            Stretch="UniformToFill"/>
                </StackPanel>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
